{
  "family": "trajectory-task-definition",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::123456789012:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::123456789012:role/trajectoryTaskRole",
  "containerDefinitions": [
    {
      "name": "trajectory-backend",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/trajectory-backend:latest",
      "cpu": 512,
      "memory": 1024,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:postgresql://trajectory-db.c1234567890.us-east-1.rds.amazonaws.com:5432/trajectory_os" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "dbadmin" },
        { "name": "SPRING_DATA_REDIS_HOST", "value": "trajectory-cache.c12345.us-east-1.cache.amazonaws.com" },
        { "name": "SPRING_DATA_REDIS_PORT", "value": "6379" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "AWS_S3_ENDPOINT", "value": "https://s3.us-east-1.amazonaws.com" },
        { "name": "AWS_BUCKET_RESUMES", "value": "trajectory-prod-resumes" },
        { "name": "AWS_BUCKET_COMPANY_DOCS", "value": "trajectory-prod-company-docs" }
      ],
      "secrets": [
        { "name": "SPRING_DATASOURCE_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:trajectory-db-pwd" },
        { "name": "JWT_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:trajectory-jwt-key" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trajectory-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    },
    {
      "name": "trajectory-frontend",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/trajectory-frontend:latest",
      "cpu": 512,
      "memory": 1024,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trajectory-frontend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ]
}
