# =========================================================================
# Trajectory OS - Production Environment Configurations (Template)
# =========================================================================

# --- Google OAuth2 Credentials ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- GitHub OAuth2 Credentials ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- Groq / Spring AI API Key ---
SPRING_AI_OPENAI_API_KEY=your-groq-api-key

# --- Database Configurations (AWS RDS PostgreSQL) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint:5432/your-db-name
SPRING_DATASOURCE_USERNAME=your-username
SPRING_DATASOURCE_PASSWORD=your-password

# --- AWS Object Storage Configurations (AWS S3) ---
AWS_REGION=your-region
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_ENDPOINT=https://s3.your-region.amazonaws.com
AWS_S3_BUCKET_RESUMES=your-resumes-bucket
AWS_S3_BUCKET_COMPANY_DOCS=your-company-docs-bucket

# --- JWT Authentication Signing Key ---
JWT_SECRET_KEY=your-256-bit-base64-encoded-jwt-secret
