# =========================================================================
# Trajectory OS Environment Configuration Template
# Copy this file to .env and fill in your actual credentials.
# =========================================================================

# --- Google OAuth2 Credentials ---
# Generate these at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- GitHub OAuth2 Credentials ---
# Generate these at https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- Groq / Spring AI API Key ---
# Required for job description parsing, scheduling analysis, and CRM checks.
# Get your API key at https://console.groq.com/
SPRING_AI_OPENAI_API_KEY=gsk_your_groq_api_key_here

# --- Database Configurations (PostgreSQL) ---
# Only needed if you run Docker Desktop or external Postgres.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/trajectory_os
SPRING_DATASOURCE_USERNAME=trajectory_user
SPRING_DATASOURCE_PASSWORD=trajectory_password

# --- Redis Host (Caching) ---
# Only needed if you run Docker Desktop or external Redis.
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# --- AWS / MinIO Object Storage Keys ---
# Only needed if you run Docker Desktop or external S3.
AWS_ACCESS_KEY_ID=trajectory_admin
AWS_SECRET_ACCESS_KEY=trajectory_storage_secret
AWS_S3_ENDPOINT=http://localhost:9000
AWS_REGION=us-east-1
